# Database
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql+asyncpg://smi:localdev@db:5432/sketchmyinfra

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-32-byte-hex

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# OAuth - Google
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev):  https://dev.sketchmyinfra.com/api/auth/google/callback
# Authorized redirect URI (prod): https://sketchmyinfra.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
# Create at: https://github.com/settings/developers
# Authorization callback URL (dev):  https://dev.sketchmyinfra.com/api/auth/github/callback
# Authorization callback URL (prod): https://sketchmyinfra.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App
# APP_URL drives OAuth callback URLs and the post-login redirect.
# Dev (via Cloudflare Tunnel):  https://dev.sketchmyinfra.com
# Prod:                         https://sketchmyinfra.com
# Pure local (no tunnel):       http://localhost
ENVIRONMENT=development
APP_URL=https://dev.sketchmyinfra.com
CORS_ORIGINS=https://dev.sketchmyinfra.com,http://localhost

# Rate limits
RATE_LIMIT_ANONYMOUS=3
RATE_LIMIT_FREE=5
